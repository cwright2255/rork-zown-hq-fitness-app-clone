{
  "expo": {
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/branding/zown-logo-512.png"
      },
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "zownhq"
            }
          ]
        }
      ],
      "package": "com.zownhq.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACTIVITY_RECOGNITION"
      ],
      "versionCode": 1
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "97962c67-b686-4470-9dd8-8e874d90b279"
      },
      "last_channel_diagnostic": "2026-07-09T16:21:00Z"
    },
    "icon": "./assets/branding/zown-logo-512.png",
    "ios": {
      "bundleIdentifier": "com.zownhq.app",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": [],
        "com.apple.developer.healthkit.background-delivery": true
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "ZOWN HQ uses the camera for food photo recognition and body scan features.",
        "NSHealthShareUsageDescription": "ZOWN HQ reads your health data to display steps, heart rate, sleep, and workout metrics.",
        "NSHealthUpdateUsageDescription": "ZOWN HQ writes workout data back to Apple Health.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ZOWN HQ uses background location to continue tracking your run even when the app is minimized.",
        "NSLocationAlwaysUsageDescription": "Allow $(PRODUCT_NAME) to use your location.",
        "NSLocationWhenInUseUsageDescription": "ZOWN HQ uses your location to track your running route and display your pace on a live map.",
        "NSMicrophoneUsageDescription": "Used for workout audio features",
        "NSPhotoLibraryUsageDescription": "ZOWN HQ accesses your photos to set a profile picture and log meals.",
        "UIBackgroundModes": [
          "location"
        ],
        "NSMotionUsageDescription": "ZOWN HQ uses motion data to count steps and track activity."
      },
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "buildNumber": "1"
    },
    "linking": {
      "config": {
        "screens": {
          "ai-coach": "ai-coach/:recommendationId",
          "profile": "profile",
          "spotify-callback": "spotify-callback",
          "workout": "workout/:workoutId"
        }
      },
      "prefixes": [
        "zownhq://",
        "https://zownhq.app"
      ]
    },
    "name": "ZOWN HQ",
    "newArchEnabled": true,
    "orientation": "portrait",
    "owner": "cwright_7",
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://zownhq.app"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "isIosBackgroundLocationEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "scheme": "zownhq",
    "sdkVersion": "54.0.0",
    "slug": "zown-hq",
    "splash": {
      "backgroundColor": "#000000",
      "image": "./assets/branding/zown-logo-512.png",
      "resizeMode": "contain"
    },
    "updates": {
      "url": "https://u.expo.dev/97962c67-b686-4470-9dd8-8e874d90b279"
    },
    "userInterfaceStyle": "automatic",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "description": "Your all-in-one fitness companion. Track workouts, runs with GPS, nutrition, and health metrics. Compete with friends, earn achievements, and own the day.",
    "primaryColor": "#000000"
  }
}